{
  "name": "wxt-vue-starter",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "description": "manifest.json description",
  "scripts": {
    "commit": "git-cz",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "vue-tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.18.1",
    "dayjs": "^1.11.21",
    "element-plus": "^2.14.2",
    "lodash-es": "^4.18.1",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.29",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@iconify/vue": "^5.0.1",
    "@wxt-dev/module-vue": "^1.0.3",
    "cz-git": "^1.13.1",
    "eslint": "^10.6.0",
    "sass": "^1.101.0",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vue-tsc": "^3.2.5",
    "wxt": "^0.20.27"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git",
      "useEmoji": true
    }
  }
}
